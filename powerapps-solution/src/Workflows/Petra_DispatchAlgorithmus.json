{
  "name": "Petra_DispatchAlgorithmus",
  "properties": {
    "connectionReferences": {},
    "displayName": "Petra – Dispatch-Algorithmus",
    "description": "Berechnet das optimale Taxi anhand der Platzkette. Kein Connector noetig - Canvas App gibt Taxi-Daten direkt mit.",
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {},
      "triggers": {
        "manual": {
          "type": "Request",
          "kind": "PowerApps",
          "inputs": {
            "schema": {
              "type": "object",
              "properties": {
                "pickupZone": {
                  "type": "string",
                  "description": "Abholzone z.B. 'E'"
                },
                "passengers": {
                  "type": "integer",
                  "description": "Anzahl Personen"
                },
                "taxis": {
                  "type": "array",
                  "description": "Liste aktiver Taxis von der Canvas App: [{id, name, position, capacity, occupied}]",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "position": {
                        "type": "string"
                      },
                      "capacity": {
                        "type": "integer"
                      },
                      "occupied": {
                        "type": "integer"
                      }
                    }
                  }
                }
              },
              "required": [
                "pickupZone",
                "passengers",
                "taxis"
              ]
            }
          }
        }
      },
      "actions": {
        "Zone_Index_Map": {
          "runAfter": {},
          "type": "Compose",
          "description": "Platzkette E=0 bis W=11",
          "inputs": {
            "E": 0,
            "F": 1,
            "H": 2,
            "I": 3,
            "A": 4,
            "B": 5,
            "C": 6,
            "D": 7,
            "T": 8,
            "G": 9,
            "P": 10,
            "W": 11
          }
        },
        "Pickup_Index": {
          "runAfter": {
            "Zone_Index_Map": [
              "Succeeded"
            ]
          },
          "type": "Compose",
          "inputs": "@outputs('Zone_Index_Map')[triggerBody()?['pickupZone']]"
        },
        "Taxis_mit_Score": {
          "runAfter": {
            "Pickup_Index": [
              "Succeeded"
            ]
          },
          "type": "Select",
          "description": "Score = Distanz zur Abholzone; nur Taxis mit freien Plaetzen",
          "inputs": {
            "from": "@triggerBody()?['taxis']",
            "select": {
              "id": "@item()?['id']",
              "name": "@item()?['name']",
              "position": "@item()?['position']",
              "freie_plaetze": "@sub(item()?['capacity'], item()?['occupied'])",
              "score": "@abs(sub(outputs('Zone_Index_Map')[item()?['position']], int(outputs('Pickup_Index'))))"
            }
          }
        },
        "Freie_Taxis": {
          "runAfter": {
            "Taxis_mit_Score": [
              "Succeeded"
            ]
          },
          "type": "Query",
          "inputs": {
            "from": "@body('Taxis_mit_Score')",
            "where": "@greaterOrEquals(item()?['freie_plaetze'], triggerBody()?['passengers'])"
          }
        },
        "Ergebnis": {
          "runAfter": {
            "Freie_Taxis": [
              "Succeeded"
            ]
          },
          "type": "Response",
          "kind": "PowerApps",
          "inputs": {
            "statusCode": 200,
            "body": {
              "empfehlung": "@body('Freie_Taxis')",
              "pickup_zone": "@triggerBody()?['pickupZone']",
              "anzahl_gefunden": "@length(body('Freie_Taxis'))"
            },
            "schema": {
              "type": "object",
              "properties": {
                "empfehlung": {
                  "type": "array"
                },
                "pickup_zone": {
                  "type": "string"
                },
                "anzahl_gefunden": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "outputs": {}
    }
  }
}